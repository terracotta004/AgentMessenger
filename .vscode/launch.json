{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "AgentMessenger: help",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/AgentMessenger.Console/bin/Debug/net10.0/AgentMessenger.Console.dll",
            "args": [
                "help"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "env": {
                "AGENT_MESSENGER_CONFIG": "${workspaceFolder}/AgentMessenger.Console/appsettings.json"
            }
        },
        {
            "name": "AgentMessenger: agents list",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/AgentMessenger.Console/bin/Debug/net10.0/AgentMessenger.Console.dll",
            "args": [
                "agents",
                "list"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "env": {
                "AGENT_MESSENGER_CONFIG": "${workspaceFolder}/AgentMessenger.Console/appsettings.json"
            }
        },
        {
            "name": "AgentMessenger: agents register ops",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/AgentMessenger.Console/bin/Debug/net10.0/AgentMessenger.Console.dll",
            "args": [
                "agents",
                "register",
                "--identity",
                "agent:ops",
                "--display-name",
                "Ops Agent",
                "--provider",
                "OpenAI",
                "--model",
                "gpt-5.4",
                "--system-prompt",
                "You coordinate operations work and respond clearly to humans and other agents.",
                "--api-key-env",
                "OPENAI_API_KEY"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "env": {
                "AGENT_MESSENGER_CONFIG": "${workspaceFolder}/AgentMessenger.Console/appsettings.json"
            }
        },
        {
            "name": "AgentMessenger: agents register Gemini research",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/AgentMessenger.Console/bin/Debug/net10.0/AgentMessenger.Console.dll",
            "args": [
                "agents",
                "register",
                "--identity",
                "agent:research",
                "--display-name",
                "Research Agent",
                "--provider",
                "Gemini",
                "--model",
                "gemini-pro",
                "--system-prompt",
                "You research questions, summarize tradeoffs, and cite uncertainty when needed.",
                "--api-key-env",
                "GEMINI_API_KEY"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "env": {
                "AGENT_MESSENGER_CONFIG": "${workspaceFolder}/AgentMessenger.Console/appsettings.json"
            }
        },
        {
            "name": "AgentMessenger: agents update identity",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/AgentMessenger.Console/bin/Debug/net10.0/AgentMessenger.Console.dll",
            "args": [
                "agents",
                "update",
                "--identity",
                "agent:assistant",
                "--new-identity",
                "agent:openai",
                "--display-name",
                "OpenAI Agent",
                "--api-key-env",
                "OPENAI_API_KEY",
                "--sync-maui"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "env": {
                "AGENT_MESSENGER_CONFIG": "${workspaceFolder}/AgentMessenger.Console/appsettings.json"
            }
        },
        {
            "name": "AgentMessenger: agents sync agent:openai MauiMessenger",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/AgentMessenger.Console/bin/Debug/net10.0/AgentMessenger.Console.dll",
