            "name": "AgentMessenger: agents sync agent:gemini MauiMessenger",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/AgentMessenger.Console/bin/Debug/net10.0/AgentMessenger.Console.dll",
            "args": [
                "agents",
                "sync",
                "--identity",
                "agent:gemini"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "env": {
                "AGENT_MESSENGER_CONFIG": "${workspaceFolder}/AgentMessenger.Console/appsettings.json"
            }
        },
