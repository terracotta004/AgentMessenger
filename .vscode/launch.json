                "agents",
                "sync",
                "--identity",
                "agent:openai"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "env": {
                "AGENT_MESSENGER_CONFIG": "${workspaceFolder}/AgentMessenger.Console/appsettings.json"
            }
        },
