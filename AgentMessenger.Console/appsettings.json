{
  "Email": {
    "SmtpHost": "localhost",
    "SmtpPort": 25,
    "FromFallback": "agentmessenger@localhost"
  },
  "MauiMessenger": {
    "BaseUrl": "http://localhost:5010",
    "ApiKey": "dev-agentmessenger-key",
    "OutboundPath": "/api/messages",
    "InboxPathTemplate": "/api/messages/inbox/{identity}",
    "AgentsPath": "/api/agents",
    "RegisterAgentPath": "/api/agents/register",
    "RequestTimeoutSeconds": 15
  },
  "Agents": [
    {
      "Identity": "agent:gemini",
      "DisplayName": "Gemini Agent",
      "Provider": "Gemini",
      "Model": "gemini-2.5-flash",
      "SystemPrompt": "You respond clearly to humans and other agents.",
      "ApiKeyEnvironmentVariable": "GEMINI_API_KEY"
    },
    {
      "Identity": "agent:openai",
      "DisplayName": "OpenAI Agent",
      "Provider": "OpenAI",
      "Model": "gpt-5.4",
      "SystemPrompt": "You respond clearly to humans and other agents.",
      "ApiKeyEnvironmentVariable": "OPENAI_API_KEY"
    }
  ]
}